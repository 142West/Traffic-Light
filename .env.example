# -----------------------------------------
# Traffic Light Controller - .env
# Copy to /home/pi/Traffic-Light/.env
# Then: chmod 600 /home/pi/Traffic-Light/.env
# -----------------------------------------

# Required -- MQTT credentials
MQTT_USER=mqttuser
MQTT_PASS=yourpassword

# Optional -- override defaults
MQTT_BROKER=homeassistant.local
MQTT_PORT=1883
DEVICE_NAME=traffic-light

# Optional -- behaviour tuning
RECONNECT_S=5
HEARTBEAT_S=30
